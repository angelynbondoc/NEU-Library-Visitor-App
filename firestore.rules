rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, email format)
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //   - college: string (required)
    //   - program: string (required)
    //   - role: string (required, 'student' or 'staff')
    //   - isApproved: boolean (optional, default false)
    //   - isAdmin: boolean (optional, default false)
    //   - isBlocked: boolean (optional, default false)
    //   - createdAt: timestamp (required)
    //
    // Collection: logs
    // Document ID: {logId} (Auto-generated)
    // Fields:
    //   - uid: string (required)
    //   - name: string (required)
    //   - college: string (required)
    //   - program: string (required)
    //   - reason: string (required)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isNEUEmail() {
      return isAuthenticated() && 
             (request.auth.uid == "0hQUIzTgpphjOrgGCu1YbEcz8aY2" || 
              request.auth.token.get('email', '').lower().endsWith("@neu.edu.ph") ||
              (request.auth.token.email != null && request.auth.token.email.lower().endsWith("@neu.edu.ph")));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDefaultAdmin() {
      return isAuthenticated() && 
             (request.auth.uid == "0hQUIzTgpphjOrgGCu1YbEcz8aY2" || 
              (request.auth.token.get('email', '') != null && 
               (request.auth.token.get('email', '').lower() == "angelyn.bondoc@neu.edu.ph" || 
                request.auth.token.get('email', '').lower() == "jcesperanza@neu.edu.ph")));
    }

    // Safe Staff check
    function isStaff() {
      return isDefaultAdmin() || (
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student') == 'staff' &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isApproved', false) == true
      );
    }

    // Safe Admin check
    function isAdmin() {
      return isDefaultAdmin() || (
             isStaff() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true
      );
    }

    function isNotBlocked() {
      let userDoc = /databases/$(database)/documents/users/$(request.auth.uid);
      return !exists(userDoc) || get(userDoc).data.get('isBlocked', false) != true;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'college', 'program', 'role', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.displayName is string && data.displayName.size() < 100 &&
             data.college is string && data.college.size() < 100 &&
             data.program is string && data.program.size() < 100 &&
             data.role in ['student', 'staff'] &&
             data.createdAt is timestamp &&
             (data.get('isApproved', true) is bool || !('isApproved' in data));
    }

    function isValidLog(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'college', 'program', 'reason', 'timestamp', 'status']) &&
             data.uid == request.auth.uid &&
             data.name is string &&
             data.email is string &&
             data.college is string &&
             data.program is string &&
             data.reason in ['Reading', 'Research', 'Use of Computer', 'Studying'] &&
             data.timestamp is timestamp &&
             data.status in ['pending', 'validated', 'blocked'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can always read their own profile.
      allow get: if request.auth.uid == userId;
      
      // Staff can read other profiles. 
      allow get: if isStaff();
      allow list: if isStaff();
      
      // Users can create their own profile if it doesn't exist.
      // They cannot set themselves as approved staff or admin (unless they are the default admin) or blocked.
      // Staff signups are allowed if they are initially NOT approved.
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                      (
                        request.resource.data.role == 'student' || 
                        (request.resource.data.role == 'staff' && request.resource.data.get('isApproved', true) == false) ||
                        isDefaultAdmin()
                      ) &&
                      (
                        request.resource.data.get('isAdmin', false) == false || 
                        request.resource.data.get('isApproved', true) == false || 
                        isDefaultAdmin()
                      ) &&
                      (request.resource.data.get('isBlocked', false) == false);
      
      // Users can update their own profile, but cannot change role, isAdmin, isBlocked, isApproved or uid/email.
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                      request.resource.data.role == resource.data.role &&
                      request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false) &&
                      request.resource.data.get('isBlocked', false) == resource.data.get('isBlocked', false) &&
                      request.resource.data.get('isApproved', true) == resource.data.get('isApproved', true) &&
                      request.resource.data.uid == resource.data.uid &&
                      request.resource.data.email == resource.data.email;
                      
      // Only admins can delete or perform other updates (like blocking or role changes).
      allow delete: if isAdmin();
      allow update: if isStaff() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isBlocked']);
      allow update: if isAdmin();
    }

    match /test/connection {
      // Allow authenticated users with NEU email to read the test connection document
      allow read: if isNEUEmail();
    }

    match /logs/{logId} {
      // Staff can read all logs. Users can read their own.
      allow get: if isNEUEmail() && (resource.data.uid == request.auth.uid || isStaff());
      allow list: if isNEUEmail() && isStaff();
      
      // Allow users to list their own logs (requires query filter)
      allow list: if isNEUEmail() && request.query.limit <= 100 && resource.data.uid == request.auth.uid;
      
      // Authenticated and non-blocked users with NEU email can create a log record.
      allow create: if isNEUEmail();
      
      // Staff can validate or block logs.
      allow update: if isStaff() && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'validatedBy', 'validatedAt']) &&
                      request.resource.data.status in ['validated', 'blocked'] &&
                      request.resource.data.validatedBy == request.auth.uid &&
                      request.resource.data.validatedAt is timestamp;

      allow delete: if isAdmin();
    }

    match /visits/{visitId} {
      // Legacy visits collection - keeping for compatibility
      allow read: if isNEUEmail() && (resource.data.uid == request.auth.uid || isStaff());
      allow create: if isNEUEmail() && isNotBlocked();
      allow update, delete: if isAdmin();
    }
  }
}
