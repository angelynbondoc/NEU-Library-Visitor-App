{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile for the library visitor app.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user (Firebase Auth UID)."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's institutional email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's full name."
        },
        "photoURL": {
          "type": "string",
          "description": "The user's profile picture URL."
        },
        "college": {
          "type": "string",
          "description": "The college or office the user belongs to."
        },
        "program": {
          "type": "string",
          "description": "The specific program or department the user is in."
        },
        "role": {
          "type": "string",
          "enum": ["student", "admin", "employee"],
          "description": "The role of the user."
        },
        "isAdmin": {
          "type": "boolean",
          "description": "Whether the user has administrative privileges."
        },
        "isEmployee": {
          "type": "boolean",
          "description": "Whether the user is a library employee."
        },
        "isBlocked": {
          "type": "boolean",
          "description": "Whether the user is blocked from entry."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the profile was created."
        }
      },
      "required": ["uid", "email", "displayName", "college", "program"]
    },
    "Log": {
      "title": "Log",
      "description": "A record of a library entry log.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The UID of the user who visited."
        },
        "name": {
          "type": "string",
          "description": "The name of the user."
        },
        "college": {
          "type": "string",
          "description": "The college of the user."
        },
        "program": {
          "type": "string",
          "description": "The program of the user."
        },
        "reason": {
          "type": "string",
          "enum": ["Reading", "Research", "Use of Computer", "Studying"],
          "description": "The reason for visiting."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "The time of the visit."
        }
      },
      "required": ["uid", "name", "college", "program", "reason", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/logs/{logId}": {
      "schema": "Log",
      "description": "Collection of library entry logs."
    },
    "/visits/{visitId}": {
      "schema": "Visit",
      "description": "Collection of library visit records (legacy)."
    }
  }
}
